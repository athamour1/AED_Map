# Copy to infra/.env on the VPS. Never commit the real infra/.env file.

POSTGRES_USER=aedmap
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aedmap

# Defaults to ghcr.io/athamour1/aed-map/api:latest (see infra/docker-compose.yml)
# — override only if the image gets pushed somewhere else.
# API_IMAGE=ghcr.io/athamour1/aed-map/api:latest

# Signs access tokens (~15min JWTs). Refresh tokens are opaque random strings,
# hashed and stored in Postgres — no separate secret needed for those.
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me

# The real origin browsers will use once a domain exists — enables the
# Origin/Referer defense-in-depth check on /auth/login and /auth/refresh
# (see plan §5). Leave unset locally; it degrades to a no-op check.
APP_ORIGIN=https://your-domain.example

# Not read by the long-running `api` container — passed ad-hoc when running
# the one-time bootstrap: docker compose exec -e ADMIN_BOOTSTRAP_EMAIL=... \
#   -e ADMIN_BOOTSTRAP_PASSWORD=... api node dist/cli/create-admin.js
